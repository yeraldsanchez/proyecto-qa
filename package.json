{
  "name": "pruebas-proyecto",
  "version": "1.0.0",
  "description": "Proyecto de pruebas QA: E2E, API y Rendimiento",
  "scripts": {
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:headed": "playwright test tests/e2e --headed",
    "test:api": "playwright test tests/api",
    "test:performance": "node scripts/run-performance.js",
    "test:performance:HU01": "k6 run tests/performance/HU01.k6.ts",
    "test:performance:HU02": "k6 run tests/performance/HU02.k6.ts",
    "test:performance:HU03": "k6 run tests/performance/HU03.k6.ts",
    "test:performance:HU04": "k6 run tests/performance/HU04.k6.ts",
    "test:performance:HU05": "k6 run tests/performance/HU05.k6.ts",
    "test:performance:HU06": "k6 run tests/performance/HU06.k6.ts",
    "test:performance:HU07": "k6 run tests/performance/HU07.k6.ts",
    "test:performance:HU08": "k6 run tests/performance/HU08.k6.ts",
    "test:performance:HU09": "k6 run tests/performance/HU09.k6.ts",
    "test:performance:HU10": "k6 run tests/performance/HU10.k6.ts",
    "test:performance:HU11": "k6 run tests/performance/HU11.k6.ts",
    "test:performance:HU12": "k6 run tests/performance/HU12.k6.ts",
    "test:performance:HU13": "k6 run tests/performance/HU13.k6.ts",
    "test:all-playwright": "playwright test",
    "test:report": "playwright show-report",
    "setup": "playwright test --config=setup.config.ts --grep \"a^\" --reporter=list"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/k6": "^0.57.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
